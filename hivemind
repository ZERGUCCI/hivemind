#!/usr/bin/env bash
# hivemind — manage the Claude + Codex hive mind across your projects.
#
#   hivemind add [--project DIR] [--global] [--link]   install (default: current project)
#   hivemind update [--project DIR | --here]           pull latest, re-sync installs
#   hivemind remove [--project DIR] [--global]         uninstall from a project
#   hivemind status                                    show versions + where it's installed
#   hivemind list                                      list registered project installs
#
# A project install lives in <project>/.claude/ and is git-excluded (never committed); other
# projects are unaffected. Uses your existing `codex login` (no API key).
set -euo pipefail

# Resolve repo root through symlinks (bash 3.2 compatible — macOS default).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"; SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$DIR/$SOURCE";; esac
done
SRC="$(cd -P "$(dirname "$SOURCE")" && pwd)"

REG_DIR="$HOME/.hivemind"
REG="$REG_DIR/installs"

repo_sha() { git -C "$SRC" rev-parse --short HEAD 2>/dev/null || echo "unknown"; }

usage() {
  cat <<'EOF'
hivemind — manage the Claude + Codex hive mind across your projects

  hivemind add [--project DIR] [--global] [--link] [--no-note]   install (default: current project)
  hivemind run <research|review|implement> [opts]    run the Codex helper (findable from any dir)
  hivemind update [--project DIR | --here]           pull latest, re-sync installs + note
  hivemind remove [--project DIR] [--global]         uninstall from a project
  hivemind status                                    show versions + where it's installed
  hivemind list                                      list registered project installs

A project install lives in <project>/.claude/ and is git-excluded — never committed, never in
`git status`, scoped to that one project. `update` pulls this repo and re-syncs every project
you've added it to. Default install is a copy; --link symlinks to this repo (auto-updates on pull).

`add` also writes a small marked note into the project's CLAUDE.md so Claude keeps reaching for the
hive mind across long sessions (skill descriptions lose salience as a session fills up). The note is
committed (use --no-note to skip); `remove` strips it.
EOF
}

register()   { mkdir -p "$REG_DIR"; touch "$REG"; grep -qxF "$1" "$REG" 2>/dev/null || printf '%s\n' "$1" >> "$REG"; }
unregister() { [ -f "$REG" ] || return 0; grep -vxF "$1" "$REG" > "$REG.tmp" 2>/dev/null || true; mv "$REG.tmp" "$REG"; }

install_into() { # $1=.claude root  $2=method(link|copy)
  local root="$1" method="$2"
  mkdir -p "$root/skills" "$root/commands"
  rm -rf "$root/skills/hivemind" "$root/commands/hivemind.md"
  if [ "$method" = "link" ]; then
    ln -s "$SRC/skills/hivemind" "$root/skills/hivemind"
    ln -s "$SRC/commands/hivemind.md" "$root/commands/hivemind.md"
  else
    cp -R "$SRC/skills/hivemind" "$root/skills/hivemind"
    cp "$SRC/commands/hivemind.md" "$root/commands/hivemind.md"
    printf '%s\n' "$(repo_sha)" > "$root/skills/hivemind/.hivemind-version"
  fi
}

git_exclude() { # $1=project dir
  local gd ex e
  gd="$(git -C "$1" rev-parse --absolute-git-dir 2>/dev/null)" || return 0
  ex="$gd/info/exclude"; mkdir -p "$(dirname "$ex")"; touch "$ex"
  for e in ".claude/skills/hivemind" ".claude/commands/hivemind.md"; do
    grep -qxF "$e" "$ex" 2>/dev/null || printf '%s\n' "$e" >> "$ex"
  done
}

# A persistent instruction in CLAUDE.md keeps Claude reaching for the skill across long sessions
# (a skill description alone loses salience as a session fills up). Managed as a marked, idempotent
# block so it can be refreshed on `update` and cleanly removed on `remove`.
note_block() {
  cat <<'EOF'

<!-- hivemind:start -->
## Hive mind (Claude + Codex) — use it, and keep using it

For any non-trivial work in this project, route through the **hivemind** skill instead of working
solo: a research/design question worth a second opinion, or any code change beyond a trivial
one-liner. Codex authors backend / backend-facing code, Claude authors frontend, each adversarially
reviews the other, then Claude synthesizes. **Keep using it across long sessions — do not drift back
to solo work as the task drags on.** Force it anytime with `/hivemind`. (Auto-managed by the
`hivemind` CLI: refresh with `hivemind update`, delete with `hivemind remove`.)
<!-- hivemind:end -->
EOF
}

strip_note() { # $1 = CLAUDE.md path — remove the hivemind block + trailing blank lines
  local md="$1" tmp
  [ -f "$md" ] || return 0
  tmp="$(dirname "$md")/.hivemind-note.tmp"
  awk '/<!-- hivemind:start -->/{s=1} /<!-- hivemind:end -->/{s=0;next} !s{print}' "$md" > "$tmp"
  awk 'NF{last=NR} {line[NR]=$0} END{for(i=1;i<=last;i++)print line[i]}' "$tmp" > "$tmp.2" && mv "$tmp.2" "$tmp"
  mv "$tmp" "$md"
}

write_note() { # $1 = CLAUDE.md path — strip any existing block, then append a fresh one
  local md="$1"
  mkdir -p "$(dirname "$md")"; touch "$md"
  strip_note "$md"
  note_block >> "$md"
}

codex_check() {
  if command -v codex >/dev/null 2>&1; then
    if [ -f "$HOME/.codex/auth.json" ]; then echo "✓ codex ready ($(codex --version 2>/dev/null))"
    else echo "✗ codex installed but not logged in — run 'codex login'"; fi
  else echo "✗ codex CLI not found — install it and run 'codex login'"; fi
}

cmd_add() {
  local scope=project method=copy target="$PWD" note=1
  while [ $# -gt 0 ]; do case "$1" in
    --project) target="${2:?--project needs a dir}"; shift 2;;
    --global)  scope=global; shift;;
    --link)    method=link; shift;;
    --copy)    method=copy; shift;;
    --no-note) note=0; shift;;
    *) echo "add: unknown arg $1" >&2; exit 1;;
  esac; done
  if [ "$scope" = global ]; then
    install_into "$HOME/.claude" "$method"
    [ "$note" = 1 ] && { write_note "$HOME/.claude/CLAUDE.md"; echo "✓ persistence note → $HOME/.claude/CLAUDE.md"; }
    echo "✓ installed hivemind globally → $HOME/.claude (method=$method, $(repo_sha))"
  else
    [ -d "$target" ] || { echo "no such dir: $target" >&2; exit 1; }
    target="$(cd "$target" && pwd)"
    install_into "$target/.claude" "$method"
    git_exclude "$target"
    register "$target"
    [ "$note" = 1 ] && { write_note "$target/CLAUDE.md"; echo "✓ persistence note → $target/CLAUDE.md (committed — keeps Claude using hivemind on long sessions; --no-note to skip)"; }
    echo "✓ installed hivemind → $target/.claude (method=$method, $(repo_sha)) — skill git-excluded, this project only"
  fi
  codex_check
  echo "Restart Claude Code so it picks up the skill."
}

cmd_update() {
  local one=""
  while [ $# -gt 0 ]; do case "$1" in
    --project) one="${2:?--project needs a dir}"; shift 2;;
    --here)    one="$PWD"; shift;;
    --all)     shift;;
    *) echo "update: unknown arg $1" >&2; exit 1;;
  esac; done
  local old new; old="$(repo_sha)"
  echo "Pulling latest hivemind into $SRC …"
  git -C "$SRC" pull --ff-only || { echo "✗ git pull failed — resolve manually in $SRC"; exit 1; }
  new="$(repo_sha)"
  echo "repo: $old → $new"
  local targets=()
  if [ -n "$one" ]; then
    targets+=("$(cd "$one" && pwd)")
  else
    if [ -f "$REG" ]; then while IFS= read -r p; do [ -n "$p" ] && targets+=("$p"); done < "$REG"; fi
    [ -d "$HOME/.claude/skills/hivemind" ] && targets+=("GLOBAL")
  fi
  if [ ${#targets[@]} -eq 0 ]; then echo "No installs registered yet. Run 'hivemind add' in a project."; return 0; fi
  local t
  for t in "${targets[@]}"; do
    if [ "$t" = GLOBAL ]; then
      if [ -e "$HOME/.claude/skills/hivemind" ]; then
        [ -L "$HOME/.claude/skills/hivemind" ] || install_into "$HOME/.claude" copy
        write_note "$HOME/.claude/CLAUDE.md"
        echo "  global: refreshed → $new"
      fi
    elif [ -d "$t" ] && [ -e "$t/.claude/skills/hivemind" ]; then
      [ -L "$t/.claude/skills/hivemind" ] || { install_into "$t/.claude" copy; git_exclude "$t"; }
      write_note "$t/CLAUDE.md"
      echo "  $t: refreshed → $new"
    else echo "  $t: not installed / gone (skipped)"; fi
  done
  echo "Done. Restart Claude Code in the updated projects."
}

cmd_remove() {
  local scope=project target="$PWD"
  while [ $# -gt 0 ]; do case "$1" in
    --project) target="${2:?--project needs a dir}"; shift 2;;
    --global)  scope=global; shift;;
    *) echo "remove: unknown arg $1" >&2; exit 1;;
  esac; done
  if [ "$scope" = global ]; then
    rm -rf "$HOME/.claude/skills/hivemind" "$HOME/.claude/commands/hivemind.md"
    strip_note "$HOME/.claude/CLAUDE.md"
    echo "✓ removed global hivemind (incl. CLAUDE.md note)"
  else
    target="$(cd "$target" && pwd)"
    rm -rf "$target/.claude/skills/hivemind" "$target/.claude/commands/hivemind.md"
    strip_note "$target/CLAUDE.md"
    unregister "$target"
    echo "✓ removed hivemind from $target (skill, CLAUDE.md note; .git/info/exclude entries left — harmless)"
  fi
}

cmd_status() {
  echo "hivemind repo:  $SRC @ $(repo_sha)"
  echo "codex:          $(codex_check)"
  echo "project installs:"
  if [ -f "$REG" ] && [ -s "$REG" ]; then
    local p v
    while IFS= read -r p; do
      [ -z "$p" ] && continue
      if [ -e "$p/.claude/skills/hivemind" ]; then
        v="$(cat "$p/.claude/skills/hivemind/.hivemind-version" 2>/dev/null || echo link)"
        echo "  ✓ $p ($v)"
      else echo "  ✗ $p (missing — 'hivemind remove --project $p' to forget)"; fi
    done < "$REG"
  else echo "  (none registered)"; fi
  [ -d "$HOME/.claude/skills/hivemind" ] && echo "  ✓ GLOBAL ($HOME/.claude)"
  return 0
}

# Run the Codex helper from THIS repo, forwarding args + stdin. Always findable (no cwd/path
# resolution), so it can't fail the way the in-skill resolver can from a subdirectory/submodule.
cmd_run() { exec node "$SRC/skills/hivemind/scripts/hivemind.mjs" "$@"; }

cmd="${1:-help}"; shift || true
case "$cmd" in
  add|install)      cmd_add "$@";;
  run)              cmd_run "$@";;
  update|upgrade)   cmd_update "$@";;
  remove|uninstall) cmd_remove "$@";;
  status)           cmd_status "$@";;
  list)             { [ -f "$REG" ] && cat "$REG"; } || echo "(none)";;
  help|-h|--help)   usage;;
  *) echo "unknown command: $cmd" >&2; usage; exit 1;;
esac
